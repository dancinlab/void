using Gtk 4.0;

template $VoidTab: Box {
  styles [
    "tab",
  ]

  orientation: vertical;
  hexpand: true;
  vexpand: true;
  title: bind $computed_title(template.config, split_tree.active-surface as <$VoidSurface>.title, split_tree.active-surface as <$VoidSurface>.title-override, template.title-override, split_tree.is-zoomed, split_tree.active-surface as <$VoidSurface>.bell-ringing) as <string>;
  tooltip: bind split_tree.active-surface as <$VoidSurface>.pwd;

  $VoidSplitTree split_tree {
    notify::active-surface => $notify_active_surface();
    notify::tree => $notify_tree();
  }
}
