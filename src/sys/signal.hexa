// signal.hexa — Signal handling via extern FFI
// VOID Layer 1: System

extern fn signal(signum: int, handler: *Void) -> *Void

// Signal constants (POSIX)
pub let sighup = 1
pub let sigint = 2
pub let sigquit = 3
pub let sigterm = 15
pub let sigchld = 20
pub let sigwinch = 28

// sig_ign = 1 (ignore signal)
pub let sig_ign = 1

fn ignore_signal(sig: int) {
  signal(sig, sig_ign)
}
