// VOID — Terminal emulator written in hexa-lang
// https://github.com/need-singularity/void

println("VOID Terminal v0.1.0")
println("====================")

// ── System FFI ─���

extern fn getpid() -> Int
extern fn getenv(name: *Byte) -> *Byte
extern fn openpty(master: *Int, slave: *Int, name: *Byte, termp: *Void, winp: *Void) -> Int
extern fn fork() -> Int
extern fn setsid() -> Int
extern fn close(fd: Int) -> Int
extern fn dup2(old: Int, new: Int) -> Int
extern fn execvp(file: *Byte, argv: *Void) -> Int
extern fn read(fd: Int, buf: *Byte, count: Int) -> Int
extern fn write(fd: Int, buf: *Byte, count: Int) -> Int
extern fn kill(pid: Int, sig: Int) -> Int
extern fn waitpid(pid: Int, status: *Int, options: Int) -> Int
extern fn usleep(usec: Int) -> Int
extern fn fcntl(fd: Int, cmd: Int, arg: Int) -> Int
extern fn malloc(size: Int) -> *Void
extern fn free(ptr: *Void)

// ── Constants ──

let F_GETFL = 3
let F_SETFL = 4
let O_NONBLOCK = 4
let SIGTERM = 15

// ── Platform Info ──

let pid = getpid()
println("[info] PID: " + str(pid))

let shell_ptr = getenv(cstring("SHELL"))
let shell = "/bin/sh"
if ptr_addr(shell_ptr) > 0 {
  shell = from_cstring(shell_ptr)
}
println("[info] Shell: " + shell)

let term_ptr = getenv(cstring("TERM"))
let term = "xterm-256color"
if ptr_addr(term_ptr) > 0 {
  term = from_cstring(term_ptr)
}
println("[info] TERM: " + term)

// ── Open PTY ──

let master_ptr = malloc(8)
let slave_ptr = malloc(8)

let ret = openpty(master_ptr, slave_ptr, ptr_null(), ptr_null(), ptr_null())
assert(ret == 0, "openpty failed: " + str(ret))

let master_fd = deref(master_ptr)
let slave_fd = deref(slave_ptr)
free(master_ptr)
free(slave_ptr)

println("[info] PTY opened: master=" + str(master_fd) + " slave=" + str(slave_fd))

// Set non-blocking on master
fcntl(master_fd, F_SETFL, O_NONBLOCK)

// ── Fork + Exec Shell ──

let child_pid = fork()
if child_pid == 0 {
  // Child: setup PTY as controlling terminal
  close(master_fd)
  setsid()
  dup2(slave_fd, 0)
  dup2(slave_fd, 1)
  dup2(slave_fd, 2)
  if slave_fd > 2 { close(slave_fd) }
  execvp(cstring(shell), ptr_null())
}

// Parent
close(slave_fd)
println("[info] Shell spawned: PID=" + str(child_pid))

// ── Main Loop (read PTY output) ──

println("[info] Reading shell output for 500ms...")
println("---")

let buf = malloc(4096)
let total_read = 0
let iterations = 0

// Simple read loop: poll PTY output
while iterations < 10 {
  usleep(50000)  // 50ms
  let n = read(master_fd, buf, 4095)
  if n > 0 {
    let output = from_cstring(buf)
    print(output)
    total_read = total_read + n
  }
  iterations = iterations + 1
}

println("")
println("---")
println("[info] Read " + str(total_read) + " bytes from PTY")

// ── Cleanup ──

let exit_cmd = cstring("exit\n")
write(master_fd, exit_cmd, 5)
usleep(100000)
kill(child_pid, SIGTERM)
waitpid(child_pid, ptr_null(), 0)
close(master_fd)
free(buf)

println("[info] VOID session ended.")
