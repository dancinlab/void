// ═══════════════════════════════════════════════════════════════
// SCREEN BUFFER — flat arrays (VP-04 compatible)
// ═══════════════════════════════════════════════════════════════
let mut COLS = 80
let mut ROWS = 24
let mut TOTAL = 1920

let mut scr_cells = []
let mut scr_fg = []
let mut scr_bg = []
let mut scr_flags = []
let mut scr_cur_x = 0
let mut scr_cur_y = 0
let mut scr_scroll_top = 0
let mut scr_scroll_bot = 23

// Alternate screen buffer (xterm ?1049/?1047/?47).
// Strategy: "swap" model — the active buffer always lives in scr_*.
// When a TUI enters the alt screen, we copy the normal buffer INTO the
// alt_* arrays (so they hold the saved normal), then clear scr_*.
// When the TUI exits, we copy alt_* back into scr_*. This keeps scr_put,
// scroll, erase, and sync_to_bridge untouched — only the mode-set entry/
// exit points need new logic.
let mut alt_cells = []
let mut alt_fg = []
let mut alt_bg = []
let mut alt_flags = []
let mut alt_cur_x = 0
let mut alt_cur_y = 0
let mut alt_saved_cur_x = 0
let mut alt_saved_cur_y = 0
let mut alt_saved_fg = 7
let mut alt_saved_bg = 0
let mut alt_saved_bold = 0
let mut alt_saved_underline = 0
let mut alt_saved_inverse = 0
let mut scr_is_alt = 0
let mut alt_buf_len = 0

fn scr_init() {
    scr_cells = []
    scr_fg = []
    scr_bg = []
    scr_flags = []
    let mut i = 0
    while i < TOTAL {
        scr_cells = scr_cells.push(32)
        scr_fg = scr_fg.push(7)
        scr_bg = scr_bg.push(0)
        scr_flags = scr_flags.push(0)
        i = i + 1
    }
    scr_cur_x = 0
    scr_cur_y = 0
    scr_scroll_top = 0
    scr_scroll_bot = ROWS - 1
    // Reset alt buffer too — keep it sized to TOTAL in lockstep.
    alt_cells = []
    alt_fg = []
    alt_bg = []
    alt_flags = []
    let mut ai = 0
    while ai < TOTAL {
        alt_cells = alt_cells.push(32)
        alt_fg = alt_fg.push(7)
        alt_bg = alt_bg.push(0)
        alt_flags = alt_flags.push(0)
        ai = ai + 1
    }
    alt_buf_len = TOTAL
    alt_cur_x = 0
    alt_cur_y = 0
    alt_saved_cur_x = 0
    alt_saved_cur_y = 0
    alt_saved_fg = 7
    alt_saved_bg = 0
    alt_saved_bold = 0
    alt_saved_underline = 0
    alt_saved_inverse = 0
    scr_is_alt = 0
    return 0
}

// Save current scr_* into alt_* (used on enter-alt).
fn alt_save_from_scr() {
    let mut i = 0
    while i < TOTAL {
        alt_cells[i] = scr_cells[i]
        alt_fg[i] = scr_fg[i]
        alt_bg[i] = scr_bg[i]
        alt_flags[i] = scr_flags[i]
        i = i + 1
    }
    alt_cur_x = scr_cur_x
    alt_cur_y = scr_cur_y
    return 0
}

// Restore saved normal from alt_* into scr_* (used on leave-alt).
fn alt_restore_to_scr() {
    let mut i = 0
    while i < TOTAL {
        scr_cells[i] = alt_cells[i]
        scr_fg[i] = alt_fg[i]
        scr_bg[i] = alt_bg[i]
        scr_flags[i] = alt_flags[i]
        i = i + 1
    }
    scr_cur_x = alt_cur_x
    scr_cur_y = alt_cur_y
    return 0
}

// Clear scr_* (used after entering alt to give the TUI a blank canvas).
fn scr_clear_all() {
    let mut i = 0
    while i < TOTAL {
        scr_cells[i] = 32
        scr_fg[i] = 7
        scr_bg[i] = 0
        scr_flags[i] = 0
        i = i + 1
    }
    scr_cur_x = 0
    scr_cur_y = 0
    return 0
}

// ?1049h — save cursor+SGR, swap to alt, clear alt, cursor→(0,0).
fn enter_alt_screen(do_save, do_clear) {
    if scr_is_alt == 1 { return 0 }
    if do_save == 1 {
        alt_saved_cur_x = scr_cur_x
        alt_saved_cur_y = scr_cur_y
        alt_saved_fg = cur_fg
        alt_saved_bg = cur_bg
        alt_saved_bold = cur_bold
        alt_saved_underline = cur_underline
        alt_saved_inverse = cur_inverse
    }
    let _ = alt_save_from_scr()
    if do_clear == 1 {
        let _ = scr_clear_all()
    } else {
        scr_cur_x = 0
        scr_cur_y = 0
    }
    scr_is_alt = 1
    return 0
}

// ?1049l — swap back to normal, restore cursor+SGR.
fn leave_alt_screen(do_restore) {
    if scr_is_alt == 0 { return 0 }
    let _ = alt_restore_to_scr()
    if do_restore == 1 {
        scr_cur_x = alt_saved_cur_x
        scr_cur_y = alt_saved_cur_y
        cur_fg = alt_saved_fg
        cur_bg = alt_saved_bg
        cur_bold = alt_saved_bold
        cur_underline = alt_saved_underline
        cur_inverse = alt_saved_inverse
    }
    scr_is_alt = 0
    return 0
}

fn scr_scroll_up() {
    // Save evicted top row to scrollback (only when scrolling from screen top)
    if scr_scroll_top == 0 {
        let _ = hexa_scrollback_push_begin()
        let mut sc = 0
        while sc < COLS {
            let _ = hexa_scrollback_push_cell(scr_cells[sc], scr_fg[sc], scr_bg[sc], scr_flags[sc])
            sc = sc + 1
        }
        let _ = hexa_scrollback_push_end()
    }
    // Shift rows within scroll region up by 1
    let mut r = scr_scroll_top
    while r < scr_scroll_bot {
        let dst = r * COLS
        let src = (r + 1) * COLS
        let mut c = 0
        while c < COLS {
            scr_cells[dst + c] = scr_cells[src + c]
            scr_fg[dst + c] = scr_fg[src + c]
            scr_bg[dst + c] = scr_bg[src + c]
            scr_flags[dst + c] = scr_flags[src + c]
            c = c + 1
        }
        r = r + 1
    }
    // Clear bottom row of scroll region
    let bot = scr_scroll_bot * COLS
    let mut c = 0
    while c < COLS {
        scr_cells[bot + c] = 32
        scr_fg[bot + c] = 7
        scr_bg[bot + c] = 0
        scr_flags[bot + c] = 0
        c = c + 1
    }
    return 0
}

fn scr_scroll_down() {
    let mut r = scr_scroll_bot
    while r > scr_scroll_top {
        let dst = r * COLS
        let src = (r - 1) * COLS
        let mut c = 0
        while c < COLS {
            scr_cells[dst + c] = scr_cells[src + c]
            scr_fg[dst + c] = scr_fg[src + c]
            scr_bg[dst + c] = scr_bg[src + c]
            scr_flags[dst + c] = scr_flags[src + c]
            c = c + 1
        }
        r = r - 1
    }
    let top = scr_scroll_top * COLS
    let mut c = 0
    while c < COLS {
        scr_cells[top + c] = 32
        scr_fg[top + c] = 7
        scr_bg[top + c] = 0
        scr_flags[top + c] = 0
        c = c + 1
    }
    return 0
}

// ═══════════════════════════════════════════════════════════════
// VT STATE MACHINE
// States: 0=GROUND 1=ESC 2=CSI 3=OSC_NUM 4=OSC_STR 5=CHARSET
// ═══════════════════════════════════════════════════════════════
let mut vt_state = 0
let mut vt_param = 0
let mut vt_params = []
let mut vt_param_started = 0
let mut vt_private = 0

// SGR state
let mut cur_fg = 7
let mut cur_bg = 0
let mut cur_bold = 0
let mut cur_underline = 0
let mut cur_inverse = 0

// OSC
let mut osc_num = 0
let mut osc_title_bytes = []

// Saved cursor
let mut saved_cur_x = 0
let mut saved_cur_y = 0

// UTF-8 decoder state
let mut utf8_cp = 0
let mut utf8_remain = 0

// Charset
let mut cur_charset = 0

fn vt_csi_reset() {
    vt_params = []
    vt_param = 0
    vt_param_started = 0
    vt_private = 0
    return 0
}

fn vt_csi_flush() {
    if vt_param_started == 1 {
        vt_params = vt_params.push(vt_param)
    }
    vt_param = 0
    vt_param_started = 0
    return 0
}

fn vt_csi_get(idx, def) {
    if idx < len(vt_params) {
        return vt_params[idx]
    }
    return def
}

// ═══════════════════════════════════════════════════════════════
// SGR — Select Graphic Rendition
// ═══════════════════════════════════════════════════════════════
fn sgr_apply() {
    let n = len(vt_params)
    if n == 0 {
        cur_fg = 7
        cur_bg = 0
        cur_bold = 0
        cur_underline = 0
        cur_inverse = 0
        return 0
    }
    let mut i = 0
    while i < n {
        let c = vt_params[i]
        if c == 0 {
            cur_fg = 7
            cur_bg = 0
            cur_bold = 0
            cur_underline = 0
            cur_inverse = 0
        } else if c == 1 {
            cur_bold = 1
        } else if c == 4 {
            cur_underline = 1
        } else if c == 7 {
            cur_inverse = 1
        } else if c == 22 {
            cur_bold = 0
        } else if c == 24 {
            cur_underline = 0
        } else if c == 27 {
            cur_inverse = 0
        } else if c == 39 {
            cur_fg = 7
        } else if c == 49 {
            cur_bg = 0
        } else if c == 38 {
            if i + 2 < n {
                if vt_params[i + 1] == 5 {
                    cur_fg = vt_params[i + 2]
                    i = i + 2
                } else if vt_params[i + 1] == 2 {
                    if i + 4 < n {
                        let r = vt_params[i + 2]
                        let g = vt_params[i + 3]
                        let b = vt_params[i + 4]
                        cur_fg = 256 + r * 65536 + g * 256 + b
                        i = i + 4
                    }
                }
            }
        } else if c == 48 {
            if i + 2 < n {
                if vt_params[i + 1] == 5 {
                    cur_bg = vt_params[i + 2]
                    i = i + 2
                } else if vt_params[i + 1] == 2 {
                    if i + 4 < n {
                        let r = vt_params[i + 2]
                        let g = vt_params[i + 3]
                        let b = vt_params[i + 4]
                        cur_bg = 256 + r * 65536 + g * 256 + b
                        i = i + 4
                    }
                }
            }
        } else if c >= 30 {
            if c <= 37 {
                cur_fg = c - 30
            } else if c >= 40 {
                if c <= 47 {
                    cur_bg = c - 40
                } else if c >= 90 {
                    if c <= 97 {
                        cur_fg = c - 90 + 8
                    } else if c >= 100 {
                        if c <= 107 {
                            cur_bg = c - 100 + 8
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    return 0
}

// ═══════════════════════════════════════════════════════════════
// CSI DISPATCH
// ═══════════════════════════════════════════════════════════════
// East Asian Wide detection — codepoints that should occupy two cells.
// Covers Hangul, CJK Unified, Hiragana/Katakana, CJK Compat, Fullwidth.
// Not perfect (no emoji ZWJ / grapheme clusters) but enough to fix the
// "한글 뒤죽박죽" bug where Korean output from claude overlapped itself.
fn is_wide_cjk(cp) {
    if cp < 0x1100 { return 0 }
    if cp >= 0x1100 && cp <= 0x115F { return 1 } // Hangul Jamo
    if cp >= 0x2E80 && cp <= 0x303E { return 1 } // CJK radicals/Kangxi/CJK symbols
    if cp == 0x3000 { return 1 }                 // Ideographic space
    if cp >= 0x3041 && cp <= 0x33FF { return 1 } // Hiragana/Katakana/CJK compat
    if cp >= 0x3400 && cp <= 0x4DBF { return 1 } // CJK Ext-A
    if cp >= 0x4E00 && cp <= 0x9FFF { return 1 } // CJK Unified
    if cp >= 0xA000 && cp <= 0xA4CF { return 1 } // Yi
    if cp >= 0xAC00 && cp <= 0xD7A3 { return 1 } // Hangul Syllables
    if cp >= 0xF900 && cp <= 0xFAFF { return 1 } // CJK Compat Ideographs
    if cp >= 0xFE30 && cp <= 0xFE4F { return 1 } // CJK Compat Forms
    if cp >= 0xFF00 && cp <= 0xFF60 { return 1 } // Fullwidth ASCII
    if cp >= 0xFFE0 && cp <= 0xFFE6 { return 1 } // Fullwidth symbols
    if cp >= 0x20000 && cp <= 0x2FFFD { return 1 } // CJK Ext-B..F
    if cp >= 0x30000 && cp <= 0x3FFFD { return 1 } // CJK Ext-G
    return 0
}

fn scr_put(cp) {
    let wide = is_wide_cjk(cp)
    let advance = if wide == 1 { 2 } else { 1 }
    if scr_cur_x + advance > COLS {
        scr_cur_x = 0
        scr_cur_y = scr_cur_y + 1
        if scr_cur_y > scr_scroll_bot {
            let _ = scr_scroll_up()
            scr_cur_y = scr_scroll_bot
        }
    }
    if scr_cur_y >= 0 {
        if scr_cur_y < ROWS {
            let idx = scr_cur_y * COLS + scr_cur_x
            scr_cells[idx] = cp
            scr_fg[idx] = cur_fg
            scr_bg[idx] = cur_bg
            let mut f = 0
            if cur_bold == 1 { f = f + 1 }
            if cur_underline == 1 { f = f + 4 }
            if cur_inverse == 1 { f = f + 8 }
            // Bit 0x10000 = wide-char head. drawRect renders 2x width.
            if wide == 1 { f = f + 0x10000 }
            scr_flags[idx] = f
            // Continuation slot — blank it out and flag bit 0x20000 so
            // drawRect skips rendering it (the wide glyph covers it).
            if wide == 1 && scr_cur_x + 1 < COLS {
                let idx2 = idx + 1
                scr_cells[idx2] = 0
                scr_fg[idx2] = cur_fg
                scr_bg[idx2] = cur_bg
                scr_flags[idx2] = 0x20000
            }
        }
    }
    scr_cur_x = scr_cur_x + advance
    return 0
}

fn csi_dispatch(b) {
    let _ = vt_csi_flush()

    if b == 72 {
        // H — CUP
        let mut row = vt_csi_get(0, 1) - 1
        let mut col = vt_csi_get(1, 1) - 1
        if row < 0 { row = 0 }
        if col < 0 { col = 0 }
        if row >= ROWS { row = ROWS - 1 }
        if col >= COLS { col = COLS - 1 }
        scr_cur_y = row
        scr_cur_x = col
    } else if b == 102 {
        // f — CUP alias
        let mut row = vt_csi_get(0, 1) - 1
        let mut col = vt_csi_get(1, 1) - 1
        if row < 0 { row = 0 }
        if col < 0 { col = 0 }
        if row >= ROWS { row = ROWS - 1 }
        if col >= COLS { col = COLS - 1 }
        scr_cur_y = row
        scr_cur_x = col
    } else if b == 65 {
        // A — CUU
        let n = vt_csi_get(0, 1)
        scr_cur_y = scr_cur_y - n
        if scr_cur_y < scr_scroll_top { scr_cur_y = scr_scroll_top }
    } else if b == 66 {
        // B — CUD
        let n = vt_csi_get(0, 1)
        scr_cur_y = scr_cur_y + n
        if scr_cur_y > scr_scroll_bot { scr_cur_y = scr_scroll_bot }
    } else if b == 67 {
        // C — CUF
        let n = vt_csi_get(0, 1)
        scr_cur_x = scr_cur_x + n
        if scr_cur_x >= COLS { scr_cur_x = COLS - 1 }
    } else if b == 68 {
        // D — CUB
        let n = vt_csi_get(0, 1)
        scr_cur_x = scr_cur_x - n
        if scr_cur_x < 0 { scr_cur_x = 0 }
    } else if b == 74 {
        // J — ED (erase display)
        let mode = vt_csi_get(0, 0)
        if mode == 0 {
            let start = scr_cur_y * COLS + scr_cur_x
            let mut i = start
            while i < TOTAL {
                scr_cells[i] = 32
                scr_fg[i] = 7
                scr_bg[i] = 0
                scr_flags[i] = 0
                i = i + 1
            }
        } else if mode == 1 {
            let stop = scr_cur_y * COLS + scr_cur_x
            let mut i = 0
            while i <= stop {
                scr_cells[i] = 32
                scr_fg[i] = 7
                scr_bg[i] = 0
                scr_flags[i] = 0
                i = i + 1
            }
        } else if mode == 2 {
            let mut i = 0
            while i < TOTAL {
                scr_cells[i] = 32
                scr_fg[i] = 7
                scr_bg[i] = 0
                scr_flags[i] = 0
                i = i + 1
            }
        }
    } else if b == 75 {
        // K — EL (erase line)
        let mode = vt_csi_get(0, 0)
        let row_s = scr_cur_y * COLS
        if mode == 0 {
            let mut i = row_s + scr_cur_x
            let row_e = row_s + COLS
            while i < row_e {
                scr_cells[i] = 32
                scr_fg[i] = 7
                scr_bg[i] = 0
                scr_flags[i] = 0
                i = i + 1
            }
        } else if mode == 1 {
            let mut i = row_s
            let stop = row_s + scr_cur_x
            while i <= stop {
                scr_cells[i] = 32
                scr_fg[i] = 7
                scr_bg[i] = 0
                scr_flags[i] = 0
                i = i + 1
            }
        } else if mode == 2 {
            let mut i = row_s
            let row_e = row_s + COLS
            while i < row_e {
                scr_cells[i] = 32
                scr_fg[i] = 7
                scr_bg[i] = 0
                scr_flags[i] = 0
                i = i + 1
            }
        }
    } else if b == 109 {
        // m — SGR
        let _ = sgr_apply()
    } else if b == 71 {
        // G — cursor horizontal absolute
        let mut col = vt_csi_get(0, 1) - 1
        if col < 0 { col = 0 }
        if col >= COLS { col = COLS - 1 }
        scr_cur_x = col
    } else if b == 100 {
        // d — vertical position absolute
        let mut row = vt_csi_get(0, 1) - 1
        if row < 0 { row = 0 }
        if row >= ROWS { row = ROWS - 1 }
        scr_cur_y = row
    } else if b == 76 {
        // L — insert lines
        let n = vt_csi_get(0, 1)
        let mut j = 0
        while j < n {
            // Shift down from bottom
            let mut r = scr_scroll_bot
            while r > scr_cur_y {
                let dst = r * COLS
                let src = (r - 1) * COLS
                let mut c = 0
                while c < COLS {
                    scr_cells[dst + c] = scr_cells[src + c]
                    scr_fg[dst + c] = scr_fg[src + c]
                    scr_bg[dst + c] = scr_bg[src + c]
                    scr_flags[dst + c] = scr_flags[src + c]
                    c = c + 1
                }
                r = r - 1
            }
            // Clear current row
            let base = scr_cur_y * COLS
            let mut c = 0
            while c < COLS {
                scr_cells[base + c] = 32
                scr_fg[base + c] = 7
                scr_bg[base + c] = 0
                scr_flags[base + c] = 0
                c = c + 1
            }
            j = j + 1
        }
    } else if b == 77 {
        // M — delete lines
        let n = vt_csi_get(0, 1)
        let mut j = 0
        while j < n {
            let mut r = scr_cur_y
            while r < scr_scroll_bot {
                let dst = r * COLS
                let src = (r + 1) * COLS
                let mut c = 0
                while c < COLS {
                    scr_cells[dst + c] = scr_cells[src + c]
                    scr_fg[dst + c] = scr_fg[src + c]
                    scr_bg[dst + c] = scr_bg[src + c]
                    scr_flags[dst + c] = scr_flags[src + c]
                    c = c + 1
                }
                r = r + 1
            }
            let base = scr_scroll_bot * COLS
            let mut c = 0
            while c < COLS {
                scr_cells[base + c] = 32
                scr_fg[base + c] = 7
                scr_bg[base + c] = 0
                scr_flags[base + c] = 0
                c = c + 1
            }
            j = j + 1
        }
    } else if b == 80 {
        // P — delete characters
        let n = vt_csi_get(0, 1)
        let row_s = scr_cur_y * COLS
        let mut i = scr_cur_x
        while i < COLS - n {
            scr_cells[row_s + i] = scr_cells[row_s + i + n]
            scr_fg[row_s + i] = scr_fg[row_s + i + n]
            scr_bg[row_s + i] = scr_bg[row_s + i + n]
            scr_flags[row_s + i] = scr_flags[row_s + i + n]
            i = i + 1
        }
        let mut j = COLS - n
        if j < scr_cur_x { j = scr_cur_x }
        while j < COLS {
            scr_cells[row_s + j] = 32
            scr_fg[row_s + j] = 7
            scr_bg[row_s + j] = 0
            scr_flags[row_s + j] = 0
            j = j + 1
        }
    } else if b == 64 {
        // @ — insert characters
        let n = vt_csi_get(0, 1)
        let row_s = scr_cur_y * COLS
        let mut i = COLS - 1
        while i >= scr_cur_x + n {
            scr_cells[row_s + i] = scr_cells[row_s + i - n]
            scr_fg[row_s + i] = scr_fg[row_s + i - n]
            scr_bg[row_s + i] = scr_bg[row_s + i - n]
            scr_flags[row_s + i] = scr_flags[row_s + i - n]
            i = i - 1
        }
        let mut j = scr_cur_x
        while j < scr_cur_x + n {
            if j < COLS {
                scr_cells[row_s + j] = 32
                scr_fg[row_s + j] = 7
                scr_bg[row_s + j] = 0
                scr_flags[row_s + j] = 0
            }
            j = j + 1
        }
    } else if b == 83 {
        // S — scroll up
        let n = vt_csi_get(0, 1)
        let mut j = 0
        while j < n {
            let _ = scr_scroll_up()
            j = j + 1
        }
    } else if b == 84 {
        // T — scroll down
        let n = vt_csi_get(0, 1)
        let mut j = 0
        while j < n {
            let _ = scr_scroll_down()
            j = j + 1
        }
    } else if b == 114 {
        // r — set scroll region
        let mut top = vt_csi_get(0, 1) - 1
        let mut bot = vt_csi_get(1, ROWS) - 1
        if top < 0 { top = 0 }
        if bot >= ROWS { bot = ROWS - 1 }
        scr_scroll_top = top
        scr_scroll_bot = bot
        scr_cur_x = 0
        scr_cur_y = 0
    } else if b == 104 {
        // h — set mode
        if vt_private == 1 {
            // ?Ph — private mode set. Handle alt-screen variants here.
            let pn = vt_csi_get(0, 0)
            if pn == 1049 {
                // ?1049h — save cursor + switch to alt + clear
                let _ = enter_alt_screen(1, 1)
            } else if pn == 1047 {
                // ?1047h — switch to alt + clear (xterm clears on entry)
                let _ = enter_alt_screen(0, 1)
            } else if pn == 47 {
                // ?47h — oldest variant, switch to alt (no save, no clear)
                let _ = enter_alt_screen(0, 0)
            } else if pn == 1048 {
                // ?1048h — save cursor only
                alt_saved_cur_x = scr_cur_x
                alt_saved_cur_y = scr_cur_y
                alt_saved_fg = cur_fg
                alt_saved_bg = cur_bg
                alt_saved_bold = cur_bold
                alt_saved_underline = cur_underline
                alt_saved_inverse = cur_inverse
            }
        }
    } else if b == 108 {
        // l — reset mode
        if vt_private == 1 {
            // ?Pl — private mode reset. Handle alt-screen variants.
            let pn = vt_csi_get(0, 0)
            if pn == 1049 {
                // ?1049l — restore normal + restore cursor
                let _ = leave_alt_screen(1)
            } else if pn == 1047 {
                // ?1047l — restore normal (no cursor restore)
                let _ = leave_alt_screen(0)
            } else if pn == 47 {
                // ?47l — restore normal (no cursor restore)
                let _ = leave_alt_screen(0)
            } else if pn == 1048 {
                // ?1048l — restore cursor only
                scr_cur_x = alt_saved_cur_x
                scr_cur_y = alt_saved_cur_y
                cur_fg = alt_saved_fg
                cur_bg = alt_saved_bg
                cur_bold = alt_saved_bold
                cur_underline = alt_saved_underline
                cur_inverse = alt_saved_inverse
            }
        }
    } else if b == 115 {
        // s — save cursor
        saved_cur_x = scr_cur_x
        saved_cur_y = scr_cur_y
    } else if b == 117 {
        // u — restore cursor
        scr_cur_x = saved_cur_x
        scr_cur_y = saved_cur_y
    }
    return 0
}

// ═══════════════════════════════════════════════════════════════
// VT FEED BYTE — main parser
// ═══════════════════════════════════════════════════════════════
fn scr_feed_byte(b) {
    // State 0: GROUND
    if vt_state == 0 {
        if b == 27 {
            // ESC introducer — also cancel any in-flight UTF-8 sequence
            // so a partial multi-byte codepoint interrupted by an escape
            // cannot absorb the bytes that follow the escape terminator.
            // See T20.
            utf8_cp = 0
            utf8_remain = 0
            vt_state = 1
        } else if b == 10 {
            // LF
            scr_cur_y = scr_cur_y + 1
            if scr_cur_y > scr_scroll_bot {
                let _ = scr_scroll_up()
                scr_cur_y = scr_scroll_bot
            }
        } else if b == 13 {
            // CR
            scr_cur_x = 0
        } else if b == 8 {
            // BS
            scr_cur_x = scr_cur_x - 1
            if scr_cur_x < 0 { scr_cur_x = 0 }
        } else if b == 9 {
            // TAB
            let rem = scr_cur_x - (scr_cur_x / 8) * 8
            scr_cur_x = scr_cur_x + (8 - rem)
            if scr_cur_x >= COLS { scr_cur_x = COLS - 1 }
        } else if b == 7 {
            // BEL — ignore
            let _ = 0
        } else if b >= 32 {
            if b < 128 {
                // ASCII printable
                let _ = scr_put(b)
            } else if b >= 192 {
                // UTF-8 lead byte
                if b < 224 {
                    // 2-byte: 110xxxxx
                    utf8_cp = b - 192
                    utf8_remain = 1
                } else if b < 240 {
                    // 3-byte: 1110xxxx
                    utf8_cp = b - 224
                    utf8_remain = 2
                } else {
                    // 4-byte: 11110xxx
                    utf8_cp = b - 240
                    utf8_remain = 3
                }
            } else {
                // Continuation byte: 10xxxxxx (128-191)
                if utf8_remain > 0 {
                    utf8_cp = utf8_cp * 64 + (b - 128)
                    utf8_remain = utf8_remain - 1
                    if utf8_remain == 0 {
                        let _ = scr_put(utf8_cp)
                    }
                }
            }
        }
        return 0
    }
    // State 1: ESC
    if vt_state == 1 {
        if b == 91 {
            // [ → CSI
            let _ = vt_csi_reset()
            vt_state = 2
        } else if b == 93 {
            // ] → OSC
            osc_num = 0
            osc_title_bytes = []
            vt_state = 3
        } else if b == 55 {
            // 7 → DECSC save cursor
            saved_cur_x = scr_cur_x
            saved_cur_y = scr_cur_y
            vt_state = 0
        } else if b == 56 {
            // 8 → DECRC restore cursor
            scr_cur_x = saved_cur_x
            scr_cur_y = saved_cur_y
            vt_state = 0
        } else if b == 77 {
            // M → reverse index
            if scr_cur_y == scr_scroll_top {
                let _ = scr_scroll_down()
            } else {
                scr_cur_y = scr_cur_y - 1
                if scr_cur_y < 0 { scr_cur_y = 0 }
            }
            vt_state = 0
        } else if b == 40 {
            // ( → charset G0
            vt_state = 5
        } else if b == 41 {
            // ) → charset G1
            vt_state = 5
        } else if b == 99 {
            // c → RIS full reset
            let _ = scr_init()
            cur_fg = 7
            cur_bg = 0
            cur_bold = 0
            cur_underline = 0
            cur_inverse = 0
            cur_charset = 0
            vt_state = 0
        } else {
            vt_state = 0
        }
        return 0
    }
    // State 2: CSI
    if vt_state == 2 {
        if b == 63 {
            // ? — private mode
            vt_private = 1
            return 0
        }
        if b >= 48 {
            if b <= 57 {
                vt_param = vt_param * 10 + (b - 48)
                vt_param_started = 1
                return 0
            }
        }
        if b == 59 {
            let _ = vt_csi_flush()
            return 0
        }
        if b >= 64 {
            if b <= 126 {
                let _ = csi_dispatch(b)
                vt_state = 0
                return 0
            }
        }
        return 0
    }
    // State 3: OSC number
    if vt_state == 3 {
        if b >= 48 {
            if b <= 57 {
                osc_num = osc_num * 10 + (b - 48)
                return 0
            }
        }
        if b == 59 {
            vt_state = 4
            return 0
        }
        if b == 7 {
            vt_state = 0
            return 0
        }
        if b == 27 {
            vt_state = 0
            return 0
        }
        return 0
    }
    // State 4: OSC string
    if vt_state == 4 {
        if b == 7 {
            // BEL — terminate OSC, apply title or cwd
            if osc_num <= 2 {
                let _ = hexa_appkit_term_title_reset()
                let mut i = 0
                while i < len(osc_title_bytes) {
                    let _ = hexa_appkit_term_title_push(osc_title_bytes[i])
                    i = i + 1
                }
                let _ = hexa_appkit_term_title_apply()
            }
            if osc_num == 7 {
                let _ = hexa_appkit_cwd_reset()
                let mut i = 0
                while i < len(osc_title_bytes) {
                    let _ = hexa_appkit_cwd_push(osc_title_bytes[i])
                    i = i + 1
                }
                let _ = hexa_appkit_cwd_apply()
            }
            vt_state = 0
            return 0
        }
        if b == 27 {
            // ESC — ST
            if osc_num <= 2 {
                let _ = hexa_appkit_term_title_reset()
                let mut i = 0
                while i < len(osc_title_bytes) {
                    let _ = hexa_appkit_term_title_push(osc_title_bytes[i])
                    i = i + 1
                }
                let _ = hexa_appkit_term_title_apply()
            }
            if osc_num == 7 {
                let _ = hexa_appkit_cwd_reset()
                let mut i = 0
                while i < len(osc_title_bytes) {
                    let _ = hexa_appkit_cwd_push(osc_title_bytes[i])
                    i = i + 1
                }
                let _ = hexa_appkit_cwd_apply()
            }
            vt_state = 0
            return 0
        }
        if osc_num <= 2 {
            osc_title_bytes = osc_title_bytes.push(b)
        }
        if osc_num == 7 {
            osc_title_bytes = osc_title_bytes.push(b)
        }
        return 0
    }
    // State 5: charset designator
    if vt_state == 5 {
        if b == 48 {
            cur_charset = 1
        } else {
            cur_charset = 0
        }
        vt_state = 0
        return 0
    }
    return 0
}

// ═══════════════════════════════════════════════════════════════
// SYNC screen buffer → AppKit bridge
// ═══════════════════════════════════════════════════════════════
fn sync_to_bridge() {
    let mut r = 0
    while r < ROWS {
        let mut c = 0
        while c < COLS {
            let idx = r * COLS + c
            let _ = hexa_appkit_term_set_cell(r, c, scr_cells[idx],
                scr_fg[idx], scr_bg[idx], scr_flags[idx])
            c = c + 1
        }
        r = r + 1
    }
    let _ = hexa_appkit_term_set_cursor(scr_cur_y, scr_cur_x, 1)
    let _ = hexa_appkit_term_flush()
    return 0
}

// ═══════════════════════════════════════════════════════════════
// SELF-TEST — headless VT + PTY pipeline verification
// ═══════════════════════════════════════════════════════════════
fn scr_find_probe(probe, probe_len) {
    let bound = TOTAL - probe_len
    let mut i = 0
    while i <= bound {
        let mut hit = 1
        let mut j = 0
        while j < probe_len {
            if scr_cells[i + j] != probe[j] {
                hit = 0
                j = probe_len
            }
            j = j + 1
        }
        if hit == 1 { return 1 }
        i = i + 1
    }
    return 0
}

fn self_test() {
    println("[void-test] === SELF-TEST START ===")
    let mut pass = 0
    let mut fail = 0

    // ── Test 1: VT parser basics ──
    let _ = scr_init()
    // Feed "ABC" → cells should be 65,66,67
    let _ = scr_feed_byte(65)
    let _ = scr_feed_byte(66)
    let _ = scr_feed_byte(67)
    if scr_cells[0] == 65 {
        if scr_cells[1] == 66 {
            if scr_cells[2] == 67 {
                println("[void-test] T1 PASS  VT print ABC")
                pass = pass + 1
            } else { println("[void-test] T1 FAIL  cell[2]=", scr_cells[2]); fail = fail + 1 }
        } else { println("[void-test] T1 FAIL  cell[1]=", scr_cells[1]); fail = fail + 1 }
    } else { println("[void-test] T1 FAIL  cell[0]=", scr_cells[0]); fail = fail + 1 }

    // ── Test 2: CUP + erase ──
    let _ = scr_init()
    // ESC[2;3H → cursor to (row=1, col=2), then write 'X'
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(50)
    let _ = scr_feed_byte(59)
    let _ = scr_feed_byte(51)
    let _ = scr_feed_byte(72)
    let _ = scr_feed_byte(88)
    let idx2 = 1 * COLS + 2
    if scr_cells[idx2] == 88 {
        println("[void-test] T2 PASS  CUP + put X at (1,2)")
        pass = pass + 1
    } else { println("[void-test] T2 FAIL  cell=", scr_cells[idx2]); fail = fail + 1 }

    // ── Test 3: SGR color ──
    let _ = scr_init()
    cur_fg = 7
    cur_bg = 0
    cur_bold = 0
    // ESC[31m → fg=1, then 'R'
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(51)
    let _ = scr_feed_byte(49)
    let _ = scr_feed_byte(109)
    let _ = scr_feed_byte(82)
    if scr_fg[0] == 1 {
        if scr_cells[0] == 82 {
            println("[void-test] T3 PASS  SGR fg=1 (red)")
            pass = pass + 1
        } else { println("[void-test] T3 FAIL  cell=", scr_cells[0]); fail = fail + 1 }
    } else { println("[void-test] T3 FAIL  fg=", scr_fg[0]); fail = fail + 1 }

    // ── Test 4: Scroll ──
    let _ = scr_init()
    cur_fg = 7
    cur_bg = 0
    cur_bold = 0
    cur_underline = 0
    cur_inverse = 0
    // Fill row 0 with 'A', move to last row, newline should scroll
    let _ = scr_feed_byte(65)
    scr_cur_y = ROWS - 1
    scr_cur_x = 0
    let _ = scr_feed_byte(66)
    // LF → should scroll up
    let _ = scr_feed_byte(10)
    // After scroll, row 0 should be empty (32), row ROWS-1 had 'B'
    // Actually 'A' was on row 0 before, now row 0 should have whatever was on row 1 (empty=32)
    if scr_cur_y == ROWS - 1 {
        println("[void-test] T4 PASS  scroll (cursor stays at bottom)")
        pass = pass + 1
    } else { println("[void-test] T4 FAIL  cur_y=", scr_cur_y); fail = fail + 1 }

    // ── Test 5: ED erase display ──
    let _ = scr_init()
    let _ = scr_feed_byte(65)
    let _ = scr_feed_byte(66)
    // ESC[2J → erase all
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(50)
    let _ = scr_feed_byte(74)
    if scr_cells[0] == 32 {
        if scr_cells[1] == 32 {
            println("[void-test] T5 PASS  ED erase all")
            pass = pass + 1
        } else { println("[void-test] T5 FAIL  cell[1]=", scr_cells[1]); fail = fail + 1 }
    } else { println("[void-test] T5 FAIL  cell[0]=", scr_cells[0]); fail = fail + 1 }

    // ── Test 6: EL erase line ──
    let _ = scr_init()
    let _ = scr_feed_byte(65)
    let _ = scr_feed_byte(66)
    let _ = scr_feed_byte(67)
    // ESC[1;2H → cursor at col 1, row 0
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(49)
    let _ = scr_feed_byte(59)
    let _ = scr_feed_byte(50)
    let _ = scr_feed_byte(72)
    // ESC[K → erase to end of line
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(75)
    if scr_cells[0] == 65 {
        if scr_cells[1] == 32 {
            if scr_cells[2] == 32 {
                println("[void-test] T6 PASS  EL erase to EOL")
                pass = pass + 1
            } else { println("[void-test] T6 FAIL  cell[2]=", scr_cells[2]); fail = fail + 1 }
        } else { println("[void-test] T6 FAIL  cell[1]=", scr_cells[1]); fail = fail + 1 }
    } else { println("[void-test] T6 FAIL  cell[0]=", scr_cells[0]); fail = fail + 1 }

    // ── Test 7: PTY spawn + drain + VT pipeline ──
    let _ = scr_init()
    cur_fg = 7
    cur_bg = 0
    cur_bold = 0
    cur_underline = 0
    cur_inverse = 0
    vt_state = 0
    let _ = hexa_sh_reset_accum()
    let m = hexa_sh_spawn()
    if m < 0 {
        println("[void-test] T7 FAIL  PTY spawn")
        fail = fail + 1
    } else {
        // Write "echo VOID-OK\n" (canned #0 is "echo hexa-term\n")
        let _ = hexa_sh_write_canned(m, 0)
        let _ = hexa_term_drain_master(m, 500)
        let _ = hexa_sh_write_canned(m, 1)
        let _ = hexa_term_drain_master(m, 500)
        let accum_n = hexa_sh_accum_len_q()
        let mut fi = 0
        while fi < accum_n {
            let b = hexa_sh_accum_byte_at(fi)
            let _ = scr_feed_byte(b)
            fi = fi + 1
        }
        let _ = hexa_sh_reap()
        // Search for "hexa-term" = [104,101,120,97,45,116,101,114,109]
        let probe = [104, 101, 120, 97, 45, 116, 101, 114, 109]
        let found = scr_find_probe(probe, 9)
        if found == 1 {
            println("[void-test] T7 PASS  PTY→VT→screen pipeline ('hexa-term' found, ", accum_n, " bytes)")
            pass = pass + 1
        } else {
            println("[void-test] T7 FAIL  probe not found in screen (", accum_n, " bytes drained)")
            fail = fail + 1
        }
    }

    // ── Test 8: OSC title parse ──
    let _ = scr_init()
    vt_state = 0
    osc_title_bytes = []
    // ESC ] 0 ; A B C BEL = 27 93 48 59 65 66 67 7
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(93)
    let _ = scr_feed_byte(48)
    let _ = scr_feed_byte(59)
    let _ = scr_feed_byte(65)
    let _ = scr_feed_byte(66)
    let _ = scr_feed_byte(67)
    let _ = scr_feed_byte(7)
    if len(osc_title_bytes) == 3 {
        if osc_title_bytes[0] == 65 {
            println("[void-test] T8 PASS  OSC 0 title parse (3 bytes)")
            pass = pass + 1
        } else { println("[void-test] T8 FAIL  title[0]=", osc_title_bytes[0]); fail = fail + 1 }
    } else { println("[void-test] T8 FAIL  title len=", len(osc_title_bytes)); fail = fail + 1 }

    // ── Test 9: Dynamic grid size ──
    COLS = 120
    ROWS = 40
    TOTAL = ROWS * COLS
    let _ = scr_init()
    let _ = vt_reset_state()
    // Fill 121 chars → 120 fills row 0, 121st wraps to row 1 col 0
    let mut t9i = 0
    while t9i < 121 {
        let _ = scr_feed_byte(65)
        t9i = t9i + 1
    }
    if scr_cur_y == 1 {
        if scr_cur_x == 1 {
            if scr_cells[120] == 65 {
                println("[void-test] T9 PASS  dynamic grid 120x40 (wrap at col 120)")
                pass = pass + 1
            } else { println("[void-test] T9 FAIL  cell[120]=", scr_cells[120]); fail = fail + 1 }
        } else { println("[void-test] T9 FAIL  cur_x=", scr_cur_x); fail = fail + 1 }
    } else { println("[void-test] T9 FAIL  cur_y=", scr_cur_y, " expected 1"); fail = fail + 1 }
    // Restore default
    COLS = 80
    ROWS = 24
    TOTAL = 1920

    // ── Test 10: UTF-8 decode (한 = U+D55C = 0xED 0x95 0x9C) ──
    let _ = scr_init()
    let _ = vt_reset_state()
    // 3-byte UTF-8: ED=237, 95=149, 9C=156
    let _ = scr_feed_byte(237)
    let _ = scr_feed_byte(149)
    let _ = scr_feed_byte(156)
    let han_cp = scr_cells[0]
    // U+D55C = 54620
    if han_cp == 54620 {
        println("[void-test] T10 PASS UTF-8 한 (U+D55C=", han_cp, ")")
        pass = pass + 1
    } else { println("[void-test] T10 FAIL  cp=", han_cp, " expected 54620"); fail = fail + 1 }

    // ── Test 11: PTY spawn with correct size + stty verification ──
    COLS = 100
    ROWS = 30
    TOTAL = ROWS * COLS
    let _ = scr_init()
    let _ = vt_reset_state()
    let _ = hexa_sh_reset_accum()
    let m11 = hexa_sh_spawn()
    if m11 < 0 {
        println("[void-test] T11 FAIL  PTY spawn")
        fail = fail + 1
    } else {
        let _ = hexa_sh_write_canned(m11, 0)
        let _ = hexa_term_drain_master(m11, 500)
        let _ = hexa_sh_write_canned(m11, 1)
        let _ = hexa_term_drain_master(m11, 500)
        let a11 = hexa_sh_accum_len_q()
        let mut fi11 = 0
        while fi11 < a11 {
            let b11 = hexa_sh_accum_byte_at(fi11)
            let _ = scr_feed_byte(b11)
            fi11 = fi11 + 1
        }
        let _ = hexa_sh_reap()
        let probe11 = [104, 101, 120, 97, 45, 116, 101, 114, 109]
        let found11 = scr_find_probe(probe11, 9)
        if found11 == 1 {
            println("[void-test] T11 PASS PTY pipeline at 100x30 (", a11, " bytes)")
            pass = pass + 1
        } else {
            println("[void-test] T11 FAIL  probe not found at 100x30")
            fail = fail + 1
        }
    }
    COLS = 80
    ROWS = 24
    TOTAL = 1920

    // ── Test 12: Tab new/close/switch ──
    // Create 3 tabs, verify count, close middle, verify
    let t12a = hexa_tab_new()
    let t12b = hexa_tab_new()
    let t12c = hexa_tab_new()
    let t12_count = hexa_tab_count()
    let t12_active = hexa_tab_get_active()
    // Close active (should be last created = t12c = index 2)
    let _ = hexa_tab_close(t12_active)
    let t12_count2 = hexa_tab_count()
    let t12_active2 = hexa_tab_get_active()
    if t12_count == 3 {
        if t12_count2 == 2 {
            if t12_active2 >= 0 {
                println("[void-test] T12 PASS tab new/close (3→close→2, active=", t12_active2, ")")
                pass = pass + 1
            } else { println("[void-test] T12 FAIL  active after close=", t12_active2); fail = fail + 1 }
        } else { println("[void-test] T12 FAIL  count after close=", t12_count2); fail = fail + 1 }
    } else { println("[void-test] T12 FAIL  initial count=", t12_count); fail = fail + 1 }
    // Cleanup remaining tabs
    let _ = hexa_tab_close(0)
    let _ = hexa_tab_close(0)

    // ── Test 13: CUU/CUD/CUF/CUB cursor movement ──
    COLS = 80
    ROWS = 24
    TOTAL = 1920
    let _ = scr_init()
    let _ = vt_reset_state()
    // Place cursor at (5,5) via CUP: ESC[6;6H
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(54)
    let _ = scr_feed_byte(59)
    let _ = scr_feed_byte(54)
    let _ = scr_feed_byte(72)
    // CUU 2: ESC[2A → row 5→3
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(50)
    let _ = scr_feed_byte(65)
    // CUF 3: ESC[3C → col 5→8
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(51)
    let _ = scr_feed_byte(67)
    // CUD 1: ESC[1B → row 3→4
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(49)
    let _ = scr_feed_byte(66)
    // CUB 4: ESC[4D → col 8→4
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(52)
    let _ = scr_feed_byte(68)
    if scr_cur_y == 4 {
        if scr_cur_x == 4 {
            println("[void-test] T13 PASS CUU/CUD/CUF/CUB (5,5)→(4,4)")
            pass = pass + 1
        } else { println("[void-test] T13 FAIL  cur_x=", scr_cur_x, " expected 4"); fail = fail + 1 }
    } else { println("[void-test] T13 FAIL  cur_y=", scr_cur_y, " expected 4"); fail = fail + 1 }

    // ── Test 14: Save/restore cursor (CSI s / CSI u) ──
    let _ = scr_init()
    let _ = vt_reset_state()
    // Move to (3,7): ESC[4;8H
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(52)
    let _ = scr_feed_byte(59)
    let _ = scr_feed_byte(56)
    let _ = scr_feed_byte(72)
    // Save: ESC[s
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(115)
    // Move somewhere else: ESC[1;1H
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(49)
    let _ = scr_feed_byte(59)
    let _ = scr_feed_byte(49)
    let _ = scr_feed_byte(72)
    // Restore: ESC[u
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(117)
    if scr_cur_y == 3 {
        if scr_cur_x == 7 {
            println("[void-test] T14 PASS save/restore cursor (3,7)")
            pass = pass + 1
        } else { println("[void-test] T14 FAIL  cur_x=", scr_cur_x, " expected 7"); fail = fail + 1 }
    } else { println("[void-test] T14 FAIL  cur_y=", scr_cur_y, " expected 3"); fail = fail + 1 }

    // ── Test 15: DECSTBM scroll region ──
    let _ = scr_init()
    let _ = vt_reset_state()
    // Set scroll region rows 3~6: ESC[3;6r
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(51)
    let _ = scr_feed_byte(59)
    let _ = scr_feed_byte(54)
    let _ = scr_feed_byte(114)
    // Put 'A' at row 2 (0-indexed) via CUP ESC[3;1H then 'A'
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(51)
    let _ = scr_feed_byte(59)
    let _ = scr_feed_byte(49)
    let _ = scr_feed_byte(72)
    let _ = scr_feed_byte(65)
    // Put marker 'Z' on row 0 (outside region)
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(49)
    let _ = scr_feed_byte(59)
    let _ = scr_feed_byte(49)
    let _ = scr_feed_byte(72)
    let _ = scr_feed_byte(90)
    // Move to bottom of region and force scroll: CUP row 6 col 1, write, LF
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(54)
    let _ = scr_feed_byte(59)
    let _ = scr_feed_byte(49)
    let _ = scr_feed_byte(72)
    let _ = scr_feed_byte(66)
    let _ = scr_feed_byte(10)
    // Row 0 'Z' should survive (outside scroll region)
    if scr_cells[0] == 90 {
        if scr_scroll_top == 2 {
            if scr_scroll_bot == 5 {
                println("[void-test] T15 PASS DECSTBM scroll region (row 0 intact)")
                pass = pass + 1
            } else { println("[void-test] T15 FAIL  scroll_bot=", scr_scroll_bot); fail = fail + 1 }
        } else { println("[void-test] T15 FAIL  scroll_top=", scr_scroll_top); fail = fail + 1 }
    } else { println("[void-test] T15 FAIL  row0[0]=", scr_cells[0], " expected 90 (Z)"); fail = fail + 1 }

    // ── Test 16: IL insert line ──
    let _ = scr_init()
    let _ = vt_reset_state()
    // Write "AB" on row 0
    let _ = scr_feed_byte(65)
    let _ = scr_feed_byte(66)
    // Move to row 0: ESC[1;1H
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(49)
    let _ = scr_feed_byte(59)
    let _ = scr_feed_byte(49)
    let _ = scr_feed_byte(72)
    // Insert 1 line: ESC[L
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(76)
    // Row 0 should be blank, row 1 should have 'A','B'
    if scr_cells[0] == 32 {
        let r1 = 1 * COLS
        if scr_cells[r1] == 65 {
            if scr_cells[r1 + 1] == 66 {
                println("[void-test] T16 PASS IL insert line (AB pushed to row 1)")
                pass = pass + 1
            } else { println("[void-test] T16 FAIL  row1[1]=", scr_cells[r1 + 1]); fail = fail + 1 }
        } else { println("[void-test] T16 FAIL  row1[0]=", scr_cells[r1]); fail = fail + 1 }
    } else { println("[void-test] T16 FAIL  row0[0]=", scr_cells[0], " expected 32"); fail = fail + 1 }

    // ── Test 17: DCH delete character ──
    let _ = scr_init()
    let _ = vt_reset_state()
    // Write "ABCDE"
    let _ = scr_feed_byte(65)
    let _ = scr_feed_byte(66)
    let _ = scr_feed_byte(67)
    let _ = scr_feed_byte(68)
    let _ = scr_feed_byte(69)
    // Move to col 1: ESC[1;2H
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(49)
    let _ = scr_feed_byte(59)
    let _ = scr_feed_byte(50)
    let _ = scr_feed_byte(72)
    // Delete 2 chars: ESC[2P
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(50)
    let _ = scr_feed_byte(80)
    // Should be: A D E _ _  (B,C deleted, D,E shift left)
    if scr_cells[0] == 65 {
        if scr_cells[1] == 68 {
            if scr_cells[2] == 69 {
                println("[void-test] T17 PASS DCH delete 2 chars (ABCDE→ADE)")
                pass = pass + 1
            } else { println("[void-test] T17 FAIL  cell[2]=", scr_cells[2], " expected 69(E)"); fail = fail + 1 }
        } else { println("[void-test] T17 FAIL  cell[1]=", scr_cells[1], " expected 68(D)"); fail = fail + 1 }
    } else { println("[void-test] T17 FAIL  cell[0]=", scr_cells[0], " expected 65(A)"); fail = fail + 1 }

    // ── Test 18: ?1049 alt screen save/restore ──
    // Write "NORM" on normal screen, enter alt (?1049h), clear+write "ALT",
    // leave alt (?1049l), verify "NORM" is restored and "ALT" is gone.
    let _ = scr_init()
    let _ = vt_reset_state()
    // Write 'N' 'O' 'R' 'M' at (0,0)..(0,3)
    let _ = scr_feed_byte(78)
    let _ = scr_feed_byte(79)
    let _ = scr_feed_byte(82)
    let _ = scr_feed_byte(77)
    // Move cursor to (0,10) via CUP ESC[1;11H
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(49)
    let _ = scr_feed_byte(59)
    let _ = scr_feed_byte(49)
    let _ = scr_feed_byte(49)
    let _ = scr_feed_byte(72)
    // ?1049h → enter alt screen: ESC [ ? 1 0 4 9 h
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(63)
    let _ = scr_feed_byte(49)
    let _ = scr_feed_byte(48)
    let _ = scr_feed_byte(52)
    let _ = scr_feed_byte(57)
    let _ = scr_feed_byte(104)
    // Alt should be blank and cursor at (0,0)
    let t18_alt_ok = if scr_cells[0] == 32 { 1 } else { 0 }
    // Write 'A','L','T' on alt at (0,0)..(0,2)
    let _ = scr_feed_byte(65)
    let _ = scr_feed_byte(76)
    let _ = scr_feed_byte(84)
    let t18_alt_write_ok = if scr_cells[0] == 65 { 1 } else { 0 }
    // ?1049l → leave alt: ESC [ ? 1 0 4 9 l
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(63)
    let _ = scr_feed_byte(49)
    let _ = scr_feed_byte(48)
    let _ = scr_feed_byte(52)
    let _ = scr_feed_byte(57)
    let _ = scr_feed_byte(108)
    // Normal should be restored: cell[0..3] = N,O,R,M and cursor at (0,10)
    if t18_alt_ok == 1 {
        if t18_alt_write_ok == 1 {
            if scr_cells[0] == 78 {
                if scr_cells[3] == 77 {
                    if scr_cur_x == 10 {
                        if scr_cur_y == 0 {
                            if scr_is_alt == 0 {
                                println("[void-test] T18 PASS ?1049 alt screen save/restore")
                                pass = pass + 1
                            } else { println("[void-test] T18 FAIL  scr_is_alt=", scr_is_alt); fail = fail + 1 }
                        } else { println("[void-test] T18 FAIL  cur_y=", scr_cur_y, " expected 0"); fail = fail + 1 }
                    } else { println("[void-test] T18 FAIL  cur_x=", scr_cur_x, " expected 10"); fail = fail + 1 }
                } else { println("[void-test] T18 FAIL  cell[3]=", scr_cells[3], " expected 77(M)"); fail = fail + 1 }
            } else { println("[void-test] T18 FAIL  cell[0]=", scr_cells[0], " expected 78(N)"); fail = fail + 1 }
        } else { println("[void-test] T18 FAIL  alt write cell[0]=", scr_cells[0]); fail = fail + 1 }
    } else { println("[void-test] T18 FAIL  alt clear cell[0]=", scr_cells[0]); fail = fail + 1 }

    // ── Test 19: cl-style multi-row table — all rows must align at col 2 ──
    // Regression guard for the "bottom half of the cl table shifted right"
    // symptom. Feeds 10 ASCII rows of the form "  | N | row_N |\r\n" and
    // checks every row starts at col 2. Any LF-without-CR bug, wide-char
    // miscount, or wrap-off-by-one immediately shifts row 7+ to the right,
    // which this test catches.
    COLS = 80
    ROWS = 24
    TOTAL = 1920
    let _ = scr_init()
    let _ = vt_reset_state()
    // Row bytes: "  | <digit> | row_<digit(s)> |" per line.
    // Precomputed as flat byte array: 16 bytes per row × 10 rows = 160 + \r\n each.
    // To keep the test compact we emit each row via a small helper loop.
    let mut t19_row = 0
    while t19_row < 10 {
        // Digit for this row (1..9, then 0 for the 10th row).
        let mut t19_dig = t19_row + 1
        if t19_dig >= 10 { t19_dig = 0 }
        let _ = scr_feed_byte(32)  // ' '
        let _ = scr_feed_byte(32)  // ' '
        let _ = scr_feed_byte(124) // '|'
        let _ = scr_feed_byte(32)  // ' '
        let _ = scr_feed_byte(48 + t19_dig) // digit
        let _ = scr_feed_byte(32)  // ' '
        let _ = scr_feed_byte(124) // '|'
        let _ = scr_feed_byte(32)  // ' '
        let _ = scr_feed_byte(114) // 'r'
        let _ = scr_feed_byte(111) // 'o'
        let _ = scr_feed_byte(119) // 'w'
        let _ = scr_feed_byte(95)  // '_'
        let _ = scr_feed_byte(48 + t19_dig)
        let _ = scr_feed_byte(32)
        let _ = scr_feed_byte(124)
        let _ = scr_feed_byte(13)  // '\r'
        let _ = scr_feed_byte(10)  // '\n'
        t19_row = t19_row + 1
    }
    // Check every row starts with '  |' at columns 0, 1, 2
    let mut t19_fail = 0
    let mut t19_r = 0
    while t19_r < 10 {
        let base = t19_r * COLS
        if scr_cells[base] != 32 { t19_fail = t19_fail + 1 }
        if scr_cells[base + 1] != 32 { t19_fail = t19_fail + 1 }
        if scr_cells[base + 2] != 124 { t19_fail = t19_fail + 1 }
        t19_r = t19_r + 1
    }
    if t19_fail == 0 {
        println("[void-test] T19 PASS cl-table 10-row alignment (all rows start at col 2)")
        pass = pass + 1
    } else {
        println("[void-test] T19 FAIL  ", t19_fail, " cells misaligned")
        fail = fail + 1
    }

    // ── Test 20: UTF-8 state reset on ESC — malformed split must not bleed ──
    // Regression guard against a UTF-8 continuation state leak where bytes
    // 128..191 after an ESC sequence get silently absorbed by the decoder
    // because utf8_remain was left > 0 by a preceding partial sequence.
    // After ESC arrives, the UTF-8 decoder state must be reset so subsequent
    // bytes are interpreted fresh.
    let _ = scr_init()
    let _ = vt_reset_state()
    // Start a 3-byte UTF-8 sequence, then ESC-interrupt before completion.
    let _ = scr_feed_byte(226) // \xe2 — 3-byte UTF-8 lead (utf8_remain=2)
    let _ = scr_feed_byte(148) // \x94 — continuation (utf8_remain=1)
    // ESC[31m — interrupt the UTF-8 sequence
    let _ = scr_feed_byte(27)
    let _ = scr_feed_byte(91)
    let _ = scr_feed_byte(51)
    let _ = scr_feed_byte(49)
    let _ = scr_feed_byte(109)
    // Now feed 'A' (65). Under the bug it would be absorbed as stale
    // UTF-8 continuation; correct behavior is to print 'A' at col 0.
    let _ = scr_feed_byte(65)
    if scr_cells[0] == 65 {
        if scr_cur_x == 1 {
            println("[void-test] T20 PASS utf8 state reset on ESC (A printed after interrupted UTF-8)")
            pass = pass + 1
        } else { println("[void-test] T20 FAIL  cur_x=", scr_cur_x, " expected 1"); fail = fail + 1 }
    } else { println("[void-test] T20 FAIL  cell[0]=", scr_cells[0], " expected 65(A)"); fail = fail + 1 }

    // ── Summary ──
    println("")
    println("[void-test] ", pass, "/", pass + fail, " passed")
    if fail == 0 {
        println("[void-test] === ALL TESTS PASS ===")
        return 0
    }
    println("[void-test] === ", fail, " FAILURES ===")
    return 1
}

// ═══════════════════════════════════════════════════════════════
// MAIN — entry point
// ═══════════════════════════════════════════════════════════════
// Load screen buffer from C's grid (after tab switch)
fn load_from_bridge() {
    let mut i = 0
    while i < TOTAL {
        scr_cells[i] = hexa_tab_cell_cp(i)
        scr_fg[i] = hexa_tab_cell_fg(i)
        scr_bg[i] = hexa_tab_cell_bg(i)
        scr_flags[i] = hexa_tab_cell_flags(i)
        i = i + 1
    }
    scr_cur_x = hexa_tab_cursor_x()
    scr_cur_y = hexa_tab_cursor_y()
    return 0
}

// Reset VT parser state (for new/switched tab)
fn vt_reset_state() {
    vt_state = 0
    vt_param = 0
    vt_params = []
    vt_param_started = 0
    vt_private = 0
    cur_fg = 7
    cur_bg = 0
    cur_bold = 0
    cur_underline = 0
    cur_inverse = 0
    osc_num = 0
    osc_title_bytes = []
    saved_cur_x = 0
    saved_cur_y = 0
    cur_charset = 0
    scr_scroll_top = 0
    scr_scroll_bot = ROWS - 1
    utf8_cp = 0
    utf8_remain = 0
    scr_is_alt = 0
    alt_saved_cur_x = 0
    alt_saved_cur_y = 0
    return 0
}

fn main() {
    // Test mode: VOID_TEST=1
    if hexa_check_test_mode() == 1 {
        return self_test()
    }

    let _ = scr_init()

    // Init AppKit terminal window (single instance, auto-sized)
    let init_r = hexa_appkit_init_term(0, 0, 14)
    if init_r < 0 {
        return 1
    }

    // Pick up auto-calculated size from C
    COLS = hexa_appkit_term_get_cols()
    ROWS = hexa_appkit_term_get_rows()
    TOTAL = ROWS * COLS
    let _ = scr_init()

    // Create first tab (spawns PTY inside C)
    let t0 = hexa_tab_new()
    if t0 < 0 {
        println("[void] FAIL: initial tab")
        return 1
    }

    // Main loop
    let mut running = 1
    while running == 1 {
        // 1. Process AppKit events
        let quit = hexa_appkit_term_poll()
        if quit == 1 {
            running = 0
        }

        // 2. Handle tab commands (Cmd+T, Cmd+W, click switch)
        let cmd = hexa_tab_poll_cmd()
        if cmd == 1 {
            // Cmd+T: new tab
            let _ = sync_to_bridge()
            let nt = hexa_tab_new()
            if nt >= 0 {
                let _ = scr_init()
                let _ = vt_reset_state()
            }
        }
        if cmd == 2 {
            // Cmd+W: close active tab
            let _ = sync_to_bridge()
            let cur_tab = hexa_tab_get_active()
            let active = hexa_tab_close(cur_tab)
            if hexa_tab_count() == 0 {
                running = 0
            } else {
                let _ = load_from_bridge()
                let _ = vt_reset_state()
            }
        }
        if cmd == 3 {
            // Tab switched (via click) — reload screen from C
            let _ = load_from_bridge()
            let _ = vt_reset_state()
        }

        // 3. Handle window resize
        if hexa_appkit_term_check_resize() == 1 {
            let new_r = hexa_appkit_term_get_rows()
            let new_c = hexa_appkit_term_get_cols()
            if new_r != ROWS {
                ROWS = new_r
            }
            if new_c != COLS {
                COLS = new_c
            }
            TOTAL = ROWS * COLS
            let _ = scr_init()
            let _ = vt_reset_state()
            // Notify PTY of new size
            let rfd = hexa_tab_get_pty()
            if rfd >= 0 {
                let _ = hexa_pty_resize(rfd, ROWS, COLS)
            }
        }

        // 4. Get active PTY
        let m = hexa_tab_get_pty()
        if m < 0 {
            let _ = hexa_sleep_us(10000)
        } else {
            // 4. Forward keys to active PTY
            let _ = hexa_keys_to_pty(m)

            // 5. Poll PTY → VT parse → sync
            let nread = hexa_pty_poll_read(m, 5)
            if nread > 0 {
                let mut i = 0
                while i < nread {
                    let b = hexa_pty_read_byte(i)
                    if b >= 0 {
                        let _ = scr_feed_byte(b)
                    }
                    i = i + 1
                }
                let _ = sync_to_bridge()
            }

            if nread == 0 {
                let _ = hexa_sleep_us(2000)
            }
        }
    }

    return 0
}
