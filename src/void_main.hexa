// ═══════════════════════════════════════════════════════════════
// EXTERN: sys_appkit.m
// ═══════════════════════════════════════════════════════════════
extern fn hexa_appkit_init_term(rows: int, cols: int, font_size: int) -> int
extern fn hexa_appkit_term_set_cell(row: int, col: int, ch: int, fg: int, bg: int, flags: int)
extern fn hexa_appkit_term_set_cursor(row: int, col: int, vis: int)
