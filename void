#!/bin/bash
# VOID — hexa-only AI-native terminal
# Usage: void           — 네이티브 macOS Cocoa 터미널
#        void --build   — 재빌드
#        void --test    — smoke 테스트
SOURCE="$0"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

HEXA="$HOME/Dev/hexa-lang/hexa"
BUILD_C="$HOME/Dev/hexa-lang/self/build_c.hexa"
MAIN="$DIR/src/void_main.hexa"
TMP_C="/tmp/void_main.c"
BIN="$DIR/void_term"
APP="$DIR/VOID.app"
APP_BIN="$APP/Contents/MacOS/void_term"

case "${1:-}" in
  --build)
    echo "[void] transpile: $MAIN → $TMP_C"
    "$HEXA" "$BUILD_C" "$MAIN" "$TMP_C" || exit 1
    echo "[void] compile: clang → $BIN"
    clang -O2 -w "$TMP_C" "$DIR/src/sys_pty.c" "$DIR/src/sys_appkit.m" \
      -ObjC -framework Cocoa -framework CoreText -lutil -o "$BIN" || exit 1
    # Copy into .app bundle
    cp "$BIN" "$APP_BIN" 2>/dev/null
    echo "[void] build OK: $BIN ($(wc -c < "$BIN" | tr -d ' ') bytes)"
    ;;
  --test)
    [ -x "$BIN" ] || { "$0" --build || exit 1; }
    VOID_TEST=1 exec "$BIN"
    ;;
  --install)
    [ -x "$BIN" ] || { "$0" --build || exit 1; }
    cp "$BIN" "$APP_BIN"
    cp -r "$APP" /Applications/VOID.app
    echo "[void] installed to /Applications/VOID.app"
    echo "[void] Spotlight: Cmd+Space → VOID"
    ;;
  --app)
    [ -x "$APP_BIN" ] || { cp "$BIN" "$APP_BIN" 2>/dev/null || { "$0" --build || exit 1; }; }
    exec open "$APP"
    ;;
  *)
    [ -x "$BIN" ] || {
      echo "[void] binary not found, building..."
      "$0" --build || exit 1
    }
    exec "$BIN" "$@"
    ;;
esac
