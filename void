#!/bin/bash
# VOID — AI-native terminal
# Usage: void          — native macOS Metal 앱 (기본)
#        void --tui    — TUI 탭 모드 (iTerm 안)
#        void --bare   — 단일 PTY (디버그용)
SOURCE="$0"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

case "${1:-}" in
  --tui|--bare)
    for p in "$HOME/Dev/hexa-lang/target/release/hexa" "$HOME/Dev/hexa-lang/target/debug/hexa"; do
      [ -x "$p" ] && HEXA="$p" && break
    done
    [ -z "$HEXA" ] && { echo "hexa not found"; exit 1; }
    trap '' INT
    case "${1:-}" in
      --tui)  exec "$HEXA" "$DIR/app/main_tabs.hexa" "${@:2}" ;;
      --bare) exec "$HEXA" "$DIR/app/main.hexa" "${@:2}" ;;
    esac
    ;;
  *)
    exec "$DIR/void_app" "$@"
    ;;
esac
