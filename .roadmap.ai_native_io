# .roadmap.ai_native_io mk2 — domain SSOT (void agent I/O channel), JSONL entry per line
# Header on next line; entries follow.
{"type":"header","kind":"domain","name":"ai_native_io","mk":2,"goal":"agent I/O protocol baked into terminal layer alongside PTY: structured tool-call + token-stream + meta channels, NO wrapper process required","required_conditions":[{"id":"ai_native_io.cond.1","desc":"AGENT channel zig-side surface API (parallel to PTY) — tool-call event boundaries + token-stream span marks","verifier":"src/terminal grep -c agent_channel","status":"unmet","evidence":[],"blocker_reason":"protocol spec frozen needed BEFORE implementation; see ai_native_io.blk.1"},{"id":"ai_native_io.cond.2","desc":"META channel — cwd, exit-code, span marks first-class (not heuristic stdout parse)","verifier":"include/void/vt grep -c VOID_META","status":"unmet","evidence":[],"blocker_reason":"depends on cond.1 protocol freeze"},{"id":"ai_native_io.cond.3","desc":"agent-channel thread distinct from read/write/render threads (per README perf budget §sys row 4)","verifier":"src/termio grep -c AgentChannel","status":"unmet","evidence":[],"blocker_reason":"threading model design pending"},{"id":"ai_native_io.cond.4","desc":"C-ABI export for libvoid embedding (third-party agent harness can speak agent channel without bundling Swift/GTK)","verifier":"include/void/vt/vt.h grep -c void_agent","status":"unmet","evidence":[],"blocker_reason":"depends on cond.1"}],"blockers":[{"id":"ai_native_io.blk.1","desc":"agent protocol specification not yet drafted — needs frame format (length-prefixed JSONL? CBOR? OSC-extended?), event type taxonomy (tool_call_start/tool_call_arg_chunk/tool_call_end/token/span_open/span_close/cwd_change/exit_code), back-pressure semantics","type":"design","status":"blocked","eta":"","resolution_path":"draft docs/design/ai_native_io_protocol.ai.md (raw 271 conformant) + 2-cycle review with hexa-lang ai_native attr SSOT cross-link"},{"id":"ai_native_io.blk.2","desc":"upstream Ghostty does NOT have this concept — divergence permanent (per VOID_FORK.md non-negotiable direction #2). cherry-pick path closed for this surface","type":"upstream","status":"accepted","eta":"","resolution_path":"document divergence in .roadmap.upstream_diverge"}],"status":"todo","since":"2026-04-21","cross_links":["void/README.md §2 AI-native I/O diagram","void/VOID_FORK.md non-negotiable direction #2","void/project.hexa ssot_attrs[ai_native]","void/.roadmap.session_persistence P7 cross-link (detached session + reattach for agent handoff)"]}
