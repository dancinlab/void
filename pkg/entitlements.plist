<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox disabled: void is a terminal emulator that runs arbitrary
	     user shells. Sandboxing would break every `cd` outside the app
	     container and defeat the purpose. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>

	<!-- Disable library validation so unsigned runtime libs (e.g. the
	     hexa stage1 runtime linked into void) don't fail codesign
	     enforcement. Without this the adhoc-signed main bundle refuses
	     to load non-system dylibs on Apple Silicon under hardened runtime. -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>

	<!-- hexa stage1 generates code into writable memory; the hexa runtime
	     also uses mmap(PROT_EXEC|PROT_WRITE) for FFI trampolines. -->
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	<key>com.apple.security.cs.allow-jit</key>
	<true/>

	<!-- Inherit DYLD_* from the launching shell so devs can override
	     load paths during iteration. -->
	<key>com.apple.security.cs.allow-dyld-environment-variables</key>
	<true/>

	<!-- Apple Events: needed if the shell inside void triggers osascript
	     or automation. Pre-authorize so macOS doesn't prompt mid-session. -->
	<key>com.apple.security.automation.apple-events</key>
	<true/>
</dict>
</plist>
