{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x .harness-engine/bin/harness ] && CLAUDE_TOOL_INPUT=\"$CLAUDE_TOOL_INPUT\" bash .harness-engine/bin/harness pre bash || true"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x .harness-engine/bin/harness ] && CLAUDE_TOOL_INPUT=\"$CLAUDE_TOOL_INPUT\" bash .harness-engine/bin/harness pre write || true"
          }
        ],
        "matcher": "Write|Edit"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x .harness-engine/bin/harness ] && bash .harness-engine/bin/harness post edit \"$CLAUDE_FILE_PATH\" || true"
          }
        ],
        "matcher": "Write|Edit"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x .harness-engine/bin/harness ] && bash .harness-engine/bin/harness prompt \"$CLAUDE_USER_PROMPT\" || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x .harness-engine/bin/harness ] && bash .harness-engine/bin/harness prefs inject || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x .harness-engine/bin/harness ] && bash .harness-engine/bin/harness easy inject || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x .harness-engine/bin/harness ] && bash .harness-engine/bin/harness recommend inject || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x .harness-engine/bin/harness ] && bash .harness-engine/bin/harness easy inject || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x .harness-engine/bin/harness ] && bash .harness-engine/bin/harness recommend inject || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "NotebookEdit",
      "Read",
      "WebFetch",
      "WebSearch",
      "Write"
    ],
    "deny": [
      "Bash(dd if=*)",
      "Bash(git push * +*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f*)",
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push -f*)",
      "Bash(mkfs*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Edit(**/shared/config/absolute_rules.json)",
      "Edit(**/shared/hooks/**)",
      "Edit(/Users/ghost/.claude/CLAUDE.md)",
      "Edit(/Users/ghost/.claude/agents/**)",
      "Edit(/Users/ghost/.claude/commands/**)",
      "Edit(/Users/ghost/.claude/hooks/**)",
      "Write(**/*.py)",
      "Write(**/*.rs)",
      "Write(**/*.sh)",
      "Write(**/shared/config/absolute_rules.json)",
      "Write(**/shared/config/core-lockdown.json)",
      "Write(**/shared/config/core.json)",
      "Write(**/shared/hooks/**)",
      "Write(/Users/ghost/.claude/CLAUDE.md)",
      "Write(/Users/ghost/.claude/agents/**)",
      "Write(/Users/ghost/.claude/commands/**)",
      "Write(/Users/ghost/.claude/hooks/**)"
    ],
    "additionalDirectories": [
      "/Users/ghost",
      "/Users/ghost/Dev/nexus"
    ],
    "defaultMode": "bypassPermissions"
  },
  "skipDangerousModePermissionPrompt": true,
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  }
}
