#!/bin/bash
# auto-build: PostToolUse hook for the void project.
#
# After any Write/Edit on a file under ~/Dev/void/src/*.m,c,hexa, build
# void_term and void_server DIRECTLY into /Applications/VOID.app/
# Contents/MacOS/ (no intermediate dev-tree copy). The running void_term
# has a kqueue thread watching that exact path and flips an internal
# flag the moment the binary is replaced; the main loop picks up the
# flag and uses NSWorkspace openApplicationAtURL + [NSApp terminate] to
# perform an in-process self-relaunch. No pkill, no osascript, no
# external open — pure AppKit.
#
# Silent on success; emits a Claude systemMessage on failure.
set -uo pipefail

# Claude Code hooks get a sparse PATH — ensure clang/git/etc are found.
export PATH="/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin"

# Pull the edited file path from the hook's stdin JSON payload.
PAYLOAD=$(cat 2>/dev/null || true)
FILE=$(printf '%s' "$PAYLOAD" | python3 -c '
import sys, json
try:
    d = json.loads(sys.stdin.read() or "{}")
except Exception:
    print("")
    sys.exit(0)
ti = d.get("tool_input") or {}
tr = d.get("tool_response") or {}
print(ti.get("file_path") or tr.get("filePath") or "")
' 2>/dev/null)

# Only rebuild when an edited file is in the void src tree.
case "$FILE" in
    */Dev/void/src/*.m|*/Dev/void/src/*.c|*/Dev/void/src/*.hexa)
        ;;
    *)
        exit 0
        ;;
esac

cd ~/Dev/void 2>/dev/null || exit 0

APP_BIN=/Applications/VOID.app/Contents/MacOS/void_term
APP_SRV=/Applications/VOID.app/Contents/MacOS/void_server

LOG=$(mktemp -t auto-build.XXXXXX)
trap 'rm -f "$LOG"' EXIT

(
    set -e
    # Build directly into a temp file, run tests, then atomic-mv into
    # the app bundle. The atomic mv is what fires the running process's
    # kqueue NOTE_DELETE/NOTE_RENAME → self_watch_thread → relaunch.
    TMP_BIN=$(mktemp -t void_term.XXXXXX)
    TMP_SRV=$(mktemp -t void_server.XXXXXX)
    clang -O2 -w -ObjC /tmp/void_main.c src/sys_pty.c src/sys_appkit.m \
        -framework Cocoa -o "$TMP_BIN"
    if [ -f src/void_server.c ]; then
        clang -O2 -w src/void_server.c -o "$TMP_SRV"
    fi
    VOID_TEST=1 "$TMP_BIN" 2>&1 | tail -3
    if [ -d /Applications/VOID.app/Contents/MacOS ]; then
        mv -f "$TMP_BIN" "$APP_BIN"
        # Re-sign with a bundle-aware ad-hoc signature. Without this,
        # the tempfile's linker-signed CodeDirectory (identifier =
        # "void_term.XXXXXX.yyy", resource-dir hash present but no
        # _CodeSignature dir) trips taskgated's "Invalid Signature"
        # check when the new process launches → SIGKILL in <20 ms,
        # crash log type 309 CODESIGNING. Re-signing after mv fixes
        # the identifier to com.need-singularity.void (from Info.plist)
        # and drops the stale resource-dir reference.
        codesign --force --sign - "$APP_BIN" 2>/dev/null
        if [ -f "$TMP_SRV" ]; then
            mv -f "$TMP_SRV" "$APP_SRV"
            codesign --force --sign - "$APP_SRV" 2>/dev/null
        fi
    fi
) > "$LOG" 2>&1

rc=$?
if [ $rc -ne 0 ]; then
    python3 - "$LOG" <<'PY' 2>/dev/null || { echo "[auto-build FAILED]" >&2; tail -50 "$LOG" >&2; }
import sys, json
with open(sys.argv[1]) as f:
    log = f.read()[-2000:]
print(json.dumps({"systemMessage": "[auto-build FAILED]\n" + log}))
PY
    exit 0
fi

# No external relaunch command — void_term's internal self-binary
# watcher reacts to the atomic mv above and triggers an NSWorkspace
# launch-new-instance + terminate dance on the main thread.
exit 0
