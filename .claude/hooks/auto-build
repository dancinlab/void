#!/bin/bash
# auto-build: PostToolUse hook for the void project.
# After any Write/Edit on a file under ~/Dev/void/src/*.m,c,hexa, rebuild
# void_term and install to /Applications/VOID.app/Contents/MacOS/. Only
# the canonical /Applications bundle is used as a runtime target — the
# ~/Dev/void/VOID.app directory is git-tracked for Info.plist / icon
# source but not installed to, to avoid LaunchServices registering the
# two paths as distinct instances (duplicate Dock tile).
# Silent on success; emits a Claude systemMessage on failure.
set -uo pipefail

# Claude Code hooks get a sparse PATH — ensure clang/git/etc are found.
export PATH="/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin"

# Pull the edited file path from the hook's stdin JSON payload.
PAYLOAD=$(cat 2>/dev/null || true)
FILE=$(printf '%s' "$PAYLOAD" | python3 -c '
import sys, json
try:
    d = json.loads(sys.stdin.read() or "{}")
except Exception:
    print("")
    sys.exit(0)
ti = d.get("tool_input") or {}
tr = d.get("tool_response") or {}
print(ti.get("file_path") or tr.get("filePath") or "")
' 2>/dev/null)

# Only rebuild when an edited file is in the void src tree.
case "$FILE" in
    */Dev/void/src/*.m|*/Dev/void/src/*.c|*/Dev/void/src/*.hexa)
        ;;
    *)
        exit 0
        ;;
esac

cd ~/Dev/void 2>/dev/null || exit 0

LOG=$(mktemp -t auto-build.XXXXXX)
trap 'rm -f "$LOG"' EXIT

(
    set -e
    clang -O2 -w -ObjC /tmp/void_main.c src/sys_pty.c src/sys_appkit.m \
        -framework Cocoa -o void_term
    if [ -f src/void_server.c ]; then
        clang -O2 -w src/void_server.c -o void_server
    fi
    # Install to /Applications ONLY (canonical launch target). Keeping
    # ~/Dev/void/VOID.app clean prevents LaunchServices from allocating
    # a second Dock tile for the same CFBundleIdentifier.
    if [ -d /Applications/VOID.app/Contents/MacOS ]; then
        cp void_term /Applications/VOID.app/Contents/MacOS/void_term
        if [ -f void_server ]; then
            cp void_server /Applications/VOID.app/Contents/MacOS/void_server
        fi
    fi
    VOID_TEST=1 ./void_term 2>&1 | tail -3
) > "$LOG" 2>&1

rc=$?
if [ $rc -ne 0 ]; then
    python3 - "$LOG" <<'PY' 2>/dev/null || { echo "[auto-build FAILED]" >&2; tail -50 "$LOG" >&2; }
import sys, json
with open(sys.argv[1]) as f:
    log = f.read()[-2000:]
print(json.dumps({"systemMessage": "[auto-build FAILED]\n" + log}))
PY
    exit 0
fi

# Auto-relaunch: after a successful build, if void_term is currently
# running, kill it and launch via /Applications/VOID.app so the user
# sees the new binary without typing anything. Skipped when
# VOID_NO_RELAUNCH=1 is set (e.g. during heavy editing where the user
# is still interacting with the current session).
#
# Session preservation note: without void-server backing, a kill loses
# all PTY state (shells, claude sessions). With VOID_USE_SERVER=1 (which
# we plan to make default next) the shells survive because the server
# holds the PTY masters.
if [ -z "${VOID_NO_RELAUNCH:-}" ]; then
    if pgrep -x void_term >/dev/null 2>&1; then
        pkill -x void_term 2>/dev/null || true
        # Small wait so the old process releases its NSWindow before
        # LaunchServices opens the new one.
        sleep 0.2
        open /Applications/VOID.app 2>/dev/null || true
    fi
fi

exit 0
