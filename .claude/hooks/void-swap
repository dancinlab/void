#!/bin/bash
# void-swap: build + launch helper for the void terminal.
#
# Canonical bundle path is /Applications/VOID.app. We install the fresh
# binary there ONLY — the ~/Dev/void/VOID.app bundle is kept in git for
# Info.plist and AppIcon.icns tracking, but is NOT a runtime launch
# target. Two separately-launchable bundles would make LaunchServices
# register them as distinct apps and produce two Dock tiles for the
# same CFBundleIdentifier.
#
# Usage: void-swap [--build-only|--signal-only]
#
# Exit codes:
#   0 — success (build + swap, or no running void_term to swap)
#   1 — build failed
#   2 — signal failed (running void_term refused or crashed)
set -uo pipefail
export PATH="/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin"

cd ~/Dev/void || exit 1

mode="${1:-all}"

if [ "$mode" != "--signal-only" ]; then
    LOG=$(mktemp -t void-swap.XXXXXX)
    trap 'rm -f "$LOG"' EXIT
    (
        set -e
        # mtime-based transpile cache (ROI #2): only re-transpile when
        # void_main.hexa is newer than /tmp/void_main.c. Saves minutes
        # when only .m/.c files changed and the hexa source is unchanged.
        HEXA_SRC=src/void_main.hexa
        HEXA_OUT=/tmp/void_main.c
        if [ -f "$HEXA_SRC" ] && [ -f "$HEXA_OUT" ]; then
            if [ "$HEXA_SRC" -nt "$HEXA_OUT" ]; then
                ~/Dev/hexa-lang/hexa ~/Dev/hexa-lang/self/build_c.hexa "$HEXA_SRC" > "$HEXA_OUT"
            fi
        elif [ -f "$HEXA_SRC" ]; then
            ~/Dev/hexa-lang/hexa ~/Dev/hexa-lang/self/build_c.hexa "$HEXA_SRC" > "$HEXA_OUT"
        fi

        clang -O2 -w -ObjC /tmp/void_main.c src/sys_pty.c src/sys_appkit.m \
            -framework Cocoa -o void_term
        # Build the server too when present. Missing source = skip.
        if [ -f src/void_server.c ]; then
            clang -O2 -w src/void_server.c -o void_server
        fi
        # Canonical install target: /Applications/VOID.app only.
        # ~/Dev/void/VOID.app is for source control of Info.plist/icns,
        # not a launch target — installing a binary there creates the
        # duplicate Dock tile issue.
        if [ -d /Applications/VOID.app/Contents/MacOS ]; then
            # Atomic mv (rename) — NEVER `cp` over a running binary.
            # `cp` writes bytes into the existing inode, which corrupts
            # the live process's mmapped code pages AND leaves the
            # bundle's ad-hoc signature pointing at stale hashes →
            # taskgated SIGKILLs the next launch with
            # "Code Signature Invalid" (bug_type 309, CODESIGNING=1).
            mv -f void_term /Applications/VOID.app/Contents/MacOS/void_term
            codesign --force --sign - /Applications/VOID.app/Contents/MacOS/void_term 2>/dev/null
            if [ -f void_server ]; then
                mv -f void_server /Applications/VOID.app/Contents/MacOS/void_server
                codesign --force --sign - /Applications/VOID.app/Contents/MacOS/void_server 2>/dev/null
            fi
        fi
        VOID_TEST=1 ./void_term 2>&1 | tail -3
    ) > "$LOG" 2>&1
    rc=$?
    if [ $rc -ne 0 ]; then
        echo "[void-swap] BUILD FAILED (exit $rc):" >&2
        tail -40 "$LOG" >&2
        exit 1
    fi
fi

if [ "$mode" = "--build-only" ]; then
    exit 0
fi

# Nothing to do at the process level — void_term's self-binary watcher
# (sys_appkit.m:install_self_binary_watcher) triggers an in-process
# NSWorkspace relaunch the moment the build above replaces the file.
# If void_term is not currently running, the user launches it manually
# from the Dock or via /Applications/VOID.app.
exit 0
